  "input_files": [
    {
      "description": "Portfolio asset inventory used by packet, gallery, audit, batch, casebook, and receipt commands.",
      "fields": [
        {
          "description": "Human-readable portfolio name.",
          "path": "name",
          "required": false,
          "type": "string"
        },
        {
          "description": "Display currency label; calculations treat values as already normalized.",
          "path": "currency",
          "required": false,
          "type": "string"
        },
        {
          "description": "Asset rows used for liquidity buckets and yield or fee assumptions.",
          "path": "assets",
          "required": true,
          "type": "array<object>"
        },
        {
          "description": "Asset display name.",
          "path": "assets[].name",
          "required": false,
          "type": "string"
        },
        {
          "description": "Gross asset value.",
          "path": "assets[].value",
          "required": true,
          "type": "number"
        },
        {
          "allowed_values": [
            "same_day",
            "one_week",
            "one_month",
            "locked"
          ],
          "description": "Liquidity bucket for stress haircut and runway grouping.",
          "path": "assets[].liquidity_tier",
          "required": true,
          "type": "enum"
        },
        {
          "description": "Annual yield assumption as a decimal, for example 0.04.",
          "path": "assets[].annual_yield_rate",
          "required": true,
          "type": "number"
        },
        {
          "description": "Annual fee assumption as a decimal, for example 0.01.",
          "path": "assets[].annual_fee_rate",
          "required": true,
          "type": "number"
        }
      ],
      "file": "portfolio.json",
      "required_fields": [
        "name",
        "currency",
        "assets"
      ]
    },
    {
      "description": "Recurring income, recurring expenses, and scheduled cash events.",
      "fields": [
        {
          "description": "Expected monthly income before scenario multiplier.",
          "path": "monthly_income",
          "required": true,
          "type": "number"
        },
        {
          "description": "Expected monthly expenses before scenario multiplier.",
          "path": "monthly_expenses",
          "required": true,
          "type": "number"
        },
        {
          "description": "One-time inflow or outflow events by month.",
          "path": "scheduled_events",
          "required": false,
          "type": "array<object>"
        },
        {
          "description": "1-based month in the runway window.",
          "path": "scheduled_events[].month",
          "required": true,
          "type": "integer"
        },
        {
          "allowed_values": [
            "inflow",
            "outflow"
          ],
          "description": "Cash event direction.",
          "path": "scheduled_events[].type",
          "required": true,
          "type": "enum"
        },
        {
          "description": "Event label for review.",
          "path": "scheduled_events[].label",
          "required": false,
          "type": "string"
        },
        {
          "description": "Positive event amount.",
          "path": "scheduled_events[].amount",
          "required": true,
          "type": "number"
        }
      ],
      "file": "ledger.json",
      "required_fields": [
        "monthly_income",
        "monthly_expenses",
        "scheduled_events"
      ]
    },
    {
      "description": "Runway window, reserve threshold, default scenario, and named scenario stress assumptions.",
      "fields": [
        {
          "description": "Number of monthly runway rows to produce.",
          "path": "months",
          "required": true,
          "type": "integer"
        },
        {
          "description": "Same-day reserve threshold used for warnings.",
          "path": "target_reserve_months",
          "required": true,
          "type": "number"
        },
        {
          "description": "Scenario used when no scenario argument is supplied.",
          "path": "default_scenario",
          "required": false,
          "type": "string"
        },
        {
          "description": "Named scenario map.",
          "path": "scenarios",
          "required": true,
          "type": "object"
        },
        {
          "description": "Multiplier applied to monthly expenses.",
          "path": "scenarios.<name>.expense_multiplier",
          "required": true,
          "type": "number"
        },
        {
          "description": "Multiplier applied to monthly income.",
          "path": "scenarios.<name>.income_multiplier",
          "required": true,
          "type": "number"
        },
        {
          "description": "Haircut map keyed by liquidity tier.",
          "path": "scenarios.<name>.liquidity_haircuts",
          "required": true,
          "type": "object"
        },
        {
          "description": "Haircut from 0 to 1.",
          "path": "scenarios.<name>.liquidity_haircuts.same_day",
          "required": true,
          "type": "number"
        },
        {
          "description": "Haircut from 0 to 1.",
          "path": "scenarios.<name>.liquidity_haircuts.one_week",
          "required": true,
          "type": "number"
        },
        {
          "description": "Haircut from 0 to 1.",
          "path": "scenarios.<name>.liquidity_haircuts.one_month",
          "required": true,
          "type": "number"
        },
        {
          "description": "Haircut from 0 to 1.",
          "path": "scenarios.<name>.liquidity_haircuts.locked",
          "required": true,
          "type": "number"
        }
      ],
      "file": "assumptions.json",
      "required_fields": [
        "months",
        "target_reserve_months",
        "default_scenario",
        "scenarios"
      ]
    },
    {
      "description": "Historical reserve and burn snapshots for compare-history.",
      "fields": [
        {
          "description": "At least two snapshots.",
          "path": "snapshots",
          "required": true,
          "type": "array<object>"
        },
        {
          "description": "Snapshot label.",
          "path": "snapshots[].label",
          "required": true,
          "type": "string"
        },
        {
          "description": "Reserve-month value for delta comparison.",
          "path": "snapshots[].same_day_reserve_months",
          "required": true,
          "type": "number"
        },
        {
          "description": "Monthly burn value for delta comparison.",
          "path": "snapshots[].effective_monthly_burn",
          "required": true,
          "type": "number"
        }
      ],
      "file": "history.json",
      "required_fields": [
        "snapshots"
      ]
    },
    {
      "description": "CSV asset rows accepted by csv-import and input-lint.",
      "fields": [
        {
          "description": "Asset display name.",
          "path": "name",
          "required": true,
          "type": "string"
        },
        {
          "description": "Gross asset value.",
          "path": "value",
          "required": true,
          "type": "number"
        },
        {
          "allowed_values": [
            "same_day",
            "one_week",
            "one_month",
            "locked"
          ],
          "description": "Liquidity bucket copied into portfolio.assets[].liquidity_tier.",
          "path": "liquidity_tier",
          "required": true,
          "type": "enum"
        },
        {
          "description": "Annual yield assumption as a decimal.",
          "path": "annual_yield_rate",
          "required": true,
          "type": "number"
        },
        {
          "description": "Annual fee assumption as a decimal.",
          "path": "annual_fee_rate",
          "required": true,
          "type": "number"
        }
      ],
      "file": "portfolio.csv",
      "required_fields": [
        "name",
        "value",
        "liquidity_tier",
        "annual_yield_rate",
        "annual_fee_rate"
      ]
    },
    {
      "description": "CSV settings and scheduled event rows accepted by csv-import and input-lint.",
      "fields": [
        {
          "allowed_values": [
            "settings",
            "event"
          ],
          "description": "settings row supplies recurring values; event rows supply scheduled events.",
          "path": "record_type",
          "required": true,
          "type": "enum"
        },
        {
          "description": "Monthly income for the single settings row.",
          "path": "monthly_income",
          "required": "settings",
          "type": "number"
        },
        {
          "description": "Monthly expenses for the single settings row.",
          "path": "monthly_expenses",
          "required": "settings",
          "type": "number"
        },
        {
          "description": "Scheduled event month.",
          "path": "month",
          "required": "event",
          "type": "integer"
        },
        {
          "allowed_values": [
            "inflow",
            "outflow"
          ],
          "description": "Scheduled event direction.",
          "path": "type",
          "required": "event",
          "type": "enum"
        },
        {
          "description": "Scheduled event label.",
          "path": "label",
          "required": false,
          "type": "string"
        },
        {
          "description": "Scheduled event amount.",
          "path": "amount",
          "required": "event",
          "type": "number"
        }
      ],
      "file": "ledger.csv",
      "required_fields": [
        "record_type",
        "monthly_income",
        "monthly_expenses",
        "month",
        "type",
        "label",
        "amount"
      ]
    }
  ],
